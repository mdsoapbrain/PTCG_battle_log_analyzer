# Runtime
APP_NAME=PTCG Battle Log Backend
APP_VERSION=0.2.0
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
API_PREFIX=

# Database
# Local SQLite (default)
DATABASE_URL=sqlite:///./backend.db

# Future Postgres/Supabase example:
# DATABASE_URL=postgresql+psycopg://postgres:password@db-host:5432/ptcg

# Frontend integration
API_BASE_URL=http://localhost:8001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-lovable-frontend.example.com

# Security / auth mode
SECRET_KEY=change-me-for-production
AUTH_MODE=stub
# AUTH_MODE options: stub | supabase_jwt
